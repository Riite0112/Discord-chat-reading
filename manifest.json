{
  "manifest_version": 3,
  "name": "Discord \u30c1\u30e3\u30c3\u30c8\u8aad\u307f\u4e0a\u3052",
  "version": "0.1.0",
  "description": "Chrome \u3067\u958b\u3044\u305f Discord \u306e\u30c1\u30e3\u30c3\u30c8\u3092\u8aad\u307f\u4e0a\u3052\u307e\u3059\u3002",
  "icons": {
    "16": "icons/icon-on-16.png",
    "32": "icons/icon-on-32.png",
    "48": "icons/icon-on-48.png",
    "128": "icons/icon-on-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "tts"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://*.discord.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-on-16.png",
      "32": "icons/icon-on-32.png"
    },
    "default_popup": "popup.html",
    "default_title": "Discord \u30c1\u30e3\u30c3\u30c8\u8aad\u307f\u4e0a\u3052"
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/channels/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
